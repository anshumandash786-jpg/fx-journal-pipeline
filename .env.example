# ═══════════════════════════════════════════════════════════
# FX Journal Pipeline — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# ═══════════════════════════════════════════════════════════

# Gemini API Key (free tier: 1,500 requests/day)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Google Sheet ID (from your sheet URL)
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=1mjLK-RlIiyghQbnqI9fTkgK86XtxsYzbj5WIkAK0JR4

# Google Drive Folder ID for screenshots
# Create a folder in Drive → ID is the last part of the URL
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id-here

# Path to Google Service Account JSON credentials
# Default: ~/.config/fx-journal/service-account.json
GOOGLE_CREDENTIALS_FILE=/Users/ansumandash126/.config/fx-journal/service-account.json

# Notion Integration# Notion Integration (visual trade journal)
NOTION_API_KEY=ntn_your_notion_api_key_here
NOTION_DATABASE_ID=your_main_trade_log_database_id_here
NOTION_DAILY_MARKUPS_DATABASE_ID=your_automated_daily_markups_database_id_here
NOTION_JOURNAL_PAGE_ID=your_backtesting_journal_page_id_here

# Telegram Bot Integration (for mobile interaction)
TELEGRAM_BOT_TOKEN=your_botfather_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
